{
  "name": "google-meetings-scheduler",
  "version": "1.0.0",
  "description": "Parse natural language meeting requests and schedule Google Calendar events with Meet links",
  "author": "Jessie / OpenClaw",
  "license": "MIT",
  "main": "skill.py",
  "entry": {
    "schedule_meeting": "skill.py:schedule_meeting"
  },
  "inputs": {
    "text": {
      "type": "string",
      "description": "Natural language meeting request (e.g., 'tomorrow 3pm with alice@example.com')"
    }
  },
  "outputs": {
    "result": {
      "type": "object",
      "properties": {
        "id": {"type": "string", "description": "Calendar event ID"},
        "summary": {"type": "string", "description": "Event title"},
        "start": {"type": "string", "description": "Start time (ISO)"},
        "end": {"type": "string", "description": "End time (ISO)"},
        "meetLink": {"type": "string", "description": "Google Meet URL"},
        "htmlLink": {"type": "string", "description": "Calendar event link"}
      }
    }
  },
  "capabilities": ["calendar", "meet", "scheduling"],
  "tags": ["google", "calendar", "meet", "scheduler", "nlp"],
  "requires": ["google-api-python-client", "google-auth", "google-auth-httplib2", "google-auth-oauthlib"],
  "env": {
    "GOOGLE_MEETINGS_SERVICE_ACCOUNT": {
      "description": "Path to Google service account JSON (optional; defaults to /home/ubuntu/openclaw-email-bot/credentials.json)",
      "required": false
    },
    "GOOGLE_MEETINGS_USER_EMAIL": {
      "description": "Calendar owner email (default: jessie@foundergraphai.com)",
      "required": false
    },
    "GOOGLE_MEETINGS_TIMEZONE": {
      "description": "Default timezone (default: Asia/Shanghai)",
      "required": false
    }
  }
}
